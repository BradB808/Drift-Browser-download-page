{
  "name": "drift-browser",
  "productName": "Drift",
  "version": "0.4.5",
  "description": "A spatial web browser — no tabs, just an infinite canvas of connected pages.",
  "license": "GPL-3.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "selftest": "electron . --selftest",
    "promoshot": "electron . --promoshot",
    "dist": "electron-builder --mac --win",
    "drm:enable": "npm install \"github:castlabs/electron-releases#v37.10.3+wvcus\" --save-dev && node build/repair-frameworks.js",
    "drm:fix": "node build/repair-frameworks.js",
    "drm:sign-dev": "python3 -m castlabs_evs.vmp sign-pkg node_modules/electron/dist",
    "drm:dist": "node build/drm-dist.js",
    "drm:verify": "electron build/widevine-check.js"
  },
  "devDependencies": {
    "electron": "github:castlabs/electron-releases#v37.10.3+wvcus",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.bradb808.drift",
    "productName": "Drift",
    "toolsets": {
      "nsis": "1.2.1"
    },
    "afterPack": "build/adhoc-sign.js",
    "files": [
      "main.js",
      "preload.js",
      "chat-preload.js",
      "ext-shims.js",
      "ext-shim-preload.js",
      "ai/**/*",
      "chat/**/*",
      "renderer/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "ext-shim-preload.js",
      "chat-preload.js",
      "node_modules/electron-chrome-extensions/**",
      "node_modules/electron-chrome-web-store/**"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "identity": null,
      "category": "public.app-category.productivity",
      "artifactName": "Drift-mac-${arch}.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "Drift-Setup.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false
    }
  },
  "dependencies": {
    "electron-chrome-extensions": "^4.9.0",
    "electron-chrome-web-store": "^0.13.0"
  }
}
